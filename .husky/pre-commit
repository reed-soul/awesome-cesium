#!/usr/bin/env sh
# Lint awesome-list READMEs when staged
for f in README.md readme-zh.md; do
  if git diff --cached --name-only | grep -q "^${f}$"; then
    echo "🔍 Running awesome-lint on ${f}..."
    npx awesome-lint "$f" 2>&1
    if [ $? -ne 0 ]; then
      echo ""
      echo "❌ awesome-lint failed on ${f}. Fix the errors above before committing."
      echo "   Run: npx awesome-lint ${f}"
      exit 1
    fi
  fi
done
